	pmid = {28430426},
	pmcid = {PMC5717763},
	keywords = {Protein Conformation, Thermodynamics, Static Electricity, HIV Protease, Macromolecular Substances, Molecular Dynamics Simulation, Mutation},
	pages = {3031--3048},
}

