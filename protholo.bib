	pmcid = {PMC7418704},
	pages = {1295--1310.e20},
	file = {Full Text:/Users/gianmarcovisani/Zotero/storage/MDVFPWCJ/Starr et al. - 2020 - Deep Mutational Scanning of SARS-CoV-2 Receptor Bi.pdf:application/pdf},
