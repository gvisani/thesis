@article{yang_pon-tstab_2018,
	title = {{PON}-tstab: {Protein} {Variant} {Stability} {Predictor}. {Importance} of {Training} {Data} {Quality}},
	volume = {19},
	copyright = {http://creativecommons.org/licenses/by/3.0/},
	issn = {1422-0067},
	shorttitle = {{PON}-tstab},
	url = {https://www.mdpi.com/1422-0067/19/4/1009},
	doi = {10.3390/ijms19041009},
	abstract = {Several methods have been developed to predict effects of amino acid substitutions on protein stability. Benchmark datasets are essential for method training and testing and have numerous requirements including that the data is representative for the investigated phenomenon. Available machine learning algorithms for variant stability have all been trained with ProTherm data. We noticed a number of issues with the contents, quality and relevance of the database. There were errors, but also features that had not been clearly communicated. Consequently, all machine learning variant stability predictors have been trained on biased and incorrect data. We obtained a corrected dataset and trained a random forests-based tool, PON-tstab, applicable to variants in any organism. Our results highlight the importance of the benchmark quality, suitability and appropriateness. Predictions are provided for three categories: stability decreasing, increasing and those not affecting stability.},
	language = {en},
	number = {4},
	urldate = {2024-07-05},
	journal = {International Journal of Molecular Sciences},
	author = {Yang, Yang and Urolagin, Siddhaling and Niroula, Abhishek and Ding, Xuesong and Shen, Bairong and Vihinen, Mauno},
	month = apr,
	year = {2018},
	note = {Number: 4
Publisher: Multidisciplinary Digital Publishing Institute},
	keywords = {benchmark quality, machine learning method, mutation, protein stability prediction, variation interpretation},
	pages = {1009},
	file = {Full Text PDF:/Users/gianmarcovisani/Zotero/storage/JLTBPR5B/Yang et al. - 2018 - PON-tstab Protein Variant Stability Predictor. Im.pdf:application/pdf},
}

@article{benevenuta_antisymmetric_2021,
	title = {An antisymmetric neural network to predict free energy changes in protein variants},
	volume = {54},
	issn = {0022-3727},
	url = {https://dx.doi.org/10.1088/1361-6463/abedfb},
	doi = {10.1088/1361-6463/abedfb},
	abstract = {The prediction of free energy changes upon protein residue variations is an important application in biophysics and biomedicine. Several methods have been developed to address this problem so far, including physical-based and machine learning models. However, most of the current computational tools, especially data-driven approaches, fail to incorporate the antisymmetric basic thermodynamic principle: a variation from wild-type to a mutated form of the protein structure () and its reverse process () must have opposite values of the free energy difference: . Here, we build a deep neural network system that, by construction, satisfies the antisymmetric properties. We show that the new method (ACDC-NN) achieved comparable or better performance with respect to other state-of-the-art approaches on both direct and reverse variations, making this method suitable for scoring new protein variants preserving the antisymmetry. The code is available at: https://github.com/compbiomed-unito/acdc-nn.},
	language = {en},
	number = {24},
	urldate = {2024-07-05},
	journal = {Journal of Physics D: Applied Physics},
	author = {Benevenuta, S. and Pancotti, C. and Fariselli, P. and Birolo, G. and Sanavia, T.},
	month = mar,
	year = {2021},
	note = {Publisher: IOP Publishing},
	pages = {245403},
}

@article{li_predicting_2020,
	title = {Predicting changes in protein thermodynamic stability upon point mutation with deep {3D} convolutional neural networks},
	volume = {16},
	issn = {1553-7358},
	url = {https://journals.plos.org/ploscompbiol/article?id=10.1371/journal.pcbi.1008291},
	doi = {10.1371/journal.pcbi.1008291},
	abstract = {Predicting mutation-induced changes in protein thermodynamic stability (ΔΔG) is of great interest in protein engineering, variant interpretation, and protein biophysics. We introduce ThermoNet, a deep, 3D-convolutional neural network (3D-CNN) designed for structure-based prediction of ΔΔGs upon point mutation. To leverage the image-processing power inherent in CNNs, we treat protein structures as if they were multi-channel 3D images. In particular, the inputs to ThermoNet are uniformly constructed as multi-channel voxel grids based on biophysical properties derived from raw atom coordinates. We train and evaluate ThermoNet with a curated data set that accounts for protein homology and is balanced with direct and reverse mutations; this provides a framework for addressing biases that have likely influenced many previous ΔΔG prediction methods. ThermoNet demonstrates performance comparable to the best available methods on the widely used Ssym test set. In addition, ThermoNet accurately predicts the effects of both stabilizing and destabilizing mutations, while most other methods exhibit a strong bias towards predicting destabilization. We further show that homology between Ssym and widely used training sets like S2648 and VariBench has likely led to overestimated performance in previous studies. Finally, we demonstrate the practical utility of ThermoNet in predicting the ΔΔGs for two clinically relevant proteins, p53 and myoglobin, and for pathogenic and benign missense variants from ClinVar. Overall, our results suggest that 3D-CNNs can model the complex, non-linear interactions perturbed by mutations, directly from biophysical properties of atoms.},
	language = {en},
	number = {11},
	urldate = {2024-07-05},
	journal = {PLOS Computational Biology},
	author = {Li, Bian and Yang, Yucheng T. and Capra, John A. and Gerstein, Mark B.},
	month = nov,
	year = {2020},
	note = {Publisher: Public Library of Science},
	keywords = {Protein structure, Protein structure prediction, Thermodynamics, Biophysics, Protein folding, Point mutation, Protein structure determination, Reverse mutation},
	pages = {e1008291},
	file = {Full Text PDF:/Users/gianmarcovisani/Zotero/storage/HKTI7478/Li et al. - 2020 - Predicting changes in protein thermodynamic stabil.pdf:application/pdf},
}

@article{caldararu_systematic_2020,
	title = {Systematic {Investigation} of the {Data} {Set} {Dependency} of {Protein} {Stability} {Predictors}},
	volume = {60},
	issn = {1549-9596},
	url = {https://doi.org/10.1021/acs.jcim.0c00591},
	doi = {10.1021/acs.jcim.0c00591},
	abstract = {Prediction of protein stability changes caused by mutation is of major importance to protein engineering and for understanding protein misfolding diseases and protein evolution. The major limitation to these applications is the fact that different prediction methods vary substantially in terms of performance for specific proteins; i.e., performance is not transferable from one type of mutation or protein to another. In this study, we investigated the performance and transferability of eight widely used methods. We first constructed a new data set composed of 2647 mutations using strict selection criteria for the experimental data and then defined a variety of subdata sets that are unbiased with respect to various aspects such as mutation type, stabilization extent, structure type, and solvent exposure. Benchmarking the methods against these subdata sets enabled us to systematically investigate how data set biases affect predictor performance. In particular, we use a reduced amino acid alphabet to quantify the bias toward mutation type, which we identify as the major bias in current approaches. Our results show that all prediction methods exhibit large biases, stemming not from failures of the models applied but mostly from the selection biases of experimental data used for training or parametrization. Our identification of these biases and the construction of new mutation-type-balanced data should lead to the development of more balanced and transferable prediction methods in the future.},
	number = {10},
	urldate = {2024-07-05},
	journal = {Journal of Chemical Information and Modeling},
	author = {Caldararu, Octav and Mehra, Rukmankesh and Blundell, Tom L. and Kepp, Kasper P.},
	month = oct,
	year = {2020},
	note = {Publisher: American Chemical Society},
	pages = {4772--4784},
	file = {Submitted Version:/Users/gianmarcovisani/Zotero/storage/ERDEYBWQ/Caldararu et al. - 2020 - Systematic Investigation of the Data Set Dependenc.pdf:application/pdf},
}

@article{lin_evolutionary-scale_2023,
	title = {Evolutionary-scale prediction of atomic-level protein structure with a language model},
