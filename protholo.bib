	keywords = {amino acids, partial least squares, peptide, principal components analysis, quantitative structure–activity relationship, stepwise multiple regression},
	pages = {775--786},
	file = {Full Text PDF:/Users/gianmarcovisani/Zotero/storage/BK6PXHZQ/Mei et al. - 2005 - A new set of amino acid descriptors and its applic.pdf:application/pdf;Snapshot:/Users/gianmarcovisani/Zotero/storage/BI79XSJ9/bip.html:text/html},
