	keywords = {Computer Science - Machine Learning, Statistics - Machine Learning, Quantitative Biology - Biomolecules},
	annote = {Comment: Presented at ICLR 2021},
	annote = {Comment: Presented at ICLR 2021},
	annote = {Comment: Presented at ICLR 2021},
	file = {arXiv Fulltext PDF:/Users/gianmarcovisani/Zotero/storage/337SIG7R/Jing et al. - 2021 - Learning from Protein Structure with Geometric Vec.pdf:application/pdf;arXiv.org Snapshot:/Users/gianmarcovisani/Zotero/storage/LTWPPIGA/2009.html:text/html;arXiv.org Snapshot:/Users/gianmarcovisani/Zotero/storage/GU686BZS/2009.html:text/html},
