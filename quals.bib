	author = {Misiura, Mikita and Shroff, Raghav and Thyer, Ross and Kolomeisky, Anatoly B.},
	urldate = {2023-10-04},
	date = {2022},
	langid = {english},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/prot.26311},
	keywords = {3DCNN, {DNN}, protein structure prediction, side chain restoration, U-net},
	file = {Snapshot:/Users/gianmarcovisani/Zotero/storage/NPKX229J/prot.html:text/html;Submitted Version:/Users/gianmarcovisani/Zotero/storage/TMPL89C4/Misiura et al. - 2022 - DLPacker Deep learning for prediction of amino ac.pdf:application/pdf},
