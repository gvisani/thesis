	keywords = {Computer Science - Computer Vision and Pattern Recognition, Computer Science - Machine Learning, Mathematics - Group Theory},
	file = {arXiv Fulltext PDF:/Users/gianmarcovisani/Zotero/storage/3AUEHR29/Bekkers et al. - 2018 - Roto-Translation Covariant Convolutional Networks .pdf:application/pdf;arXiv.org Snapshot:/Users/gianmarcovisani/Zotero/storage/CX2RE5RT/1804.html:text/html},
