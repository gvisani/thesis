@misc{fuchs_se3-transformers_2020,
	title = {{SE}(3)-Transformers: 3D Roto-Translation Equivariant Attention Networks},
	url = {http://arxiv.org/abs/2006.10503},
	doi = {10.48550/arXiv.2006.10503},
	shorttitle = {{SE}(3)-Transformers},
	abstract = {We introduce the {SE}(3)-Transformer, a variant of the self-attention module for 3D point clouds and graphs, which is equivariant under continuous 3D roto-translations. Equivariance is important to ensure stable and predictable performance in the presence of nuisance transformations of the data input. A positive corollary of equivariance is increased weight-tying within the model. The {SE}(3)-Transformer leverages the benefits of self-attention to operate on large point clouds and graphs with varying number of points, while guaranteeing {SE}(3)-equivariance for robustness. We evaluate our model on a toy N-body particle simulation dataset, showcasing the robustness of the predictions under rotations of the input. We further achieve competitive performance on two real-world datasets, {ScanObjectNN} and {QM}9. In all cases, our model outperforms a strong, non-equivariant attention baseline and an equivariant model without attention.},
	number = {{arXiv}:2006.10503},
	publisher = {{arXiv}},
	author = {Fuchs, Fabian B. and Worrall, Daniel E. and Fischer, Volker and Welling, Max},
	urldate = {2022-07-16},
	date = {2020-11-24},
	eprinttype = {arxiv},
	eprint = {2006.10503 [cs, stat]},
	keywords = {Computer Science - Machine Learning, Statistics - Machine Learning},
	file = {arXiv Fulltext PDF:/Users/gianmarcovisani/Zotero/storage/763WRMQR/Fuchs et al. - 2020 - SE(3)-Transformers 3D Roto-Translation Equivarian.pdf:application/pdf;arXiv.org Snapshot:/Users/gianmarcovisani/Zotero/storage/6QGRU2PR/2006.html:text/html},
