	eprinttype = {arxiv},
	eprint = {2102.06942 [cs]},
	keywords = {Computer Science - Computer Vision and Pattern Recognition, Computer Science - Machine Learning, Computer Science - Neural and Evolutionary Computing},
	file = {arXiv Fulltext PDF:/Users/gianmarcovisani/Zotero/storage/GTNLQFSL/Müller et al. - 2021 - Rotation-Equivariant Deep Learning for Diffusion M.pdf:application/pdf;arXiv.org Snapshot:/Users/gianmarcovisani/Zotero/storage/2IJTGC3K/2102.html:text/html},
}

