	keywords = {Computer Science - Machine Learning, Statistics - Machine Learning},
	file = {arXiv Fulltext PDF:/Users/gianmarcovisani/Zotero/storage/R96CSA88/Kondor et al. - 2018 - Clebsch-Gordan Nets a Fully Fourier Space Spheric.pdf:application/pdf;arXiv.org Snapshot:/Users/gianmarcovisani/Zotero/storage/E3UMEGUC/1806.html:text/html},
