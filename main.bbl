      \field{journaltitle}{Briefings in Bioinformatics}
      \field{month}{3}
      \field{number}{2}
      \field{shorttitle}{Predicting protein stability changes upon single-point mutation}
      \field{title}{Predicting protein stability changes upon single-point mutation: a thorough comparison of the available tools on a new dataset}
